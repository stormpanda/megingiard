<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome belt silhouette for Android 13+ themed/tinted icons.
    Represents Megingjörð (Thor's belt) with a Mjölnir shield buckle.
    All fills use #FFFFFF; the system applies the wallpaper-derived tint at runtime.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left knotwork panel -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,44 L26,44 L26,64 L12,64 Z" />

    <!-- Left strap connector (gap between panel and buckle) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M26,48 L38,48 L38,60 L26,60 Z" />

    <!--
        Center shield buckle with Mjölnir T-shape cut through (evenOdd fill rule).
        Outer: shield with pointed bottom.
        Inner cutouts: hammer head rectangle + handle rectangle.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M38,33 L70,33 L70,61 Q70,70 54,76 Q38,70 38,61 Z
                          M41,38 L67,38 L67,50 L41,50 Z
                          M50,50 L58,50 L58,65 L50,65 Z" />

    <!-- Right strap connector -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M70,48 L82,48 L82,60 L70,60 Z" />

    <!-- Right knotwork panel -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M82,44 L96,44 L96,64 L82,64 Z" />

</vector>
