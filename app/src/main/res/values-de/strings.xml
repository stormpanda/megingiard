    <!-- Privilegierter Modus -->
    <string name="privd_title">Privilegierter Modus</string>
    <string name="privd_description">Erlaubt Megingiard, direkt in System-Eingabegeräte zu schreiben, die die normale App-Sandbox nicht erreicht. Wird für einige erweiterte Funktionen benötigt (siehe unten). Die Verbindung läuft über die geräteeigene ADB-Shell — kein Root, kein externer Server.</string>
    <string name="privd_status_off">Aus</string>
    <string name="privd_status_connecting">Verbinde…</string>
    <string name="privd_status_bootstrapping">Einrichten…</string>
    <string name="privd_status_running">Aktiv</string>
    <string name="privd_status_failed">Fehlgeschlagen</string>
    <string name="privd_action_connect">Verbinden</string>
    <string name="privd_action_disconnect">Trennen</string>
    <string name="privd_action_test">Verbindung testen</string>
    <string name="privd_action_show_wizard">Einrichten…</string>
    <string name="privd_ping_ok">Daemon antwortet — Verbindung ist intakt.</string>
    <string name="privd_ping_fail">Keine Antwort vom Daemon. Die Verbindung ist möglicherweise abgebrochen.</string>

    <string name="privd_auto_connect">Beim App-Start automatisch verbinden</string>
    <string name="privd_auto_connect_desc">Wenn aktiviert, öffnet Megingiard den Daemon-Socket beim Start lautlos erneut. Wird nach erfolgreicher Erst-Einrichtung automatisch gesetzt.</string>

    <string name="privd_feature_gamepad_merge">Gamepad-Merge</string>
    <string name="privd_feature_gamepad_merge_desc">Sendet MacroPad-Gamepad-Aktionen direkt an den verbundenen physischen Controller, sodass Spiele nur ein Gerät sehen. Deaktivieren, um das klassische virtuelle Gamepad zu verwenden.</string>

    <string name="privd_feature_gamepad_recording">Physisches Gamepad aufzeichnen</string>
    <string name="privd_feature_gamepad_recording_desc">Nimmt Makro-Schritte direkt vom physischen Gamepad auf (Analogsticks, Tasten). Wenn aktiviert, nutzt die Aufnahme-Schaltfläche im Timeline-Editor den physischen Controller statt des virtuellen On-Screen-Gamepads.</string>

    <string name="privd_feature_mirror">Privilegierte Spiegelung</string>
    <string name="privd_feature_mirror_desc">Spiegelt den Primärbildschirm über den geräteinternen privilegierten Daemon (kein MediaProjection-Dialog, geringere CPU-Last). DRM-geschützte Videoframes erscheinen schwarz — wie bei scrcpy.</string>

